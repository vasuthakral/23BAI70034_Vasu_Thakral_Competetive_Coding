class Solution {
public:
    typedef long long ll;

    bool helper(long long targetTime, int n, vector<int>& batteries) {
        long long curr_avl = 0;

        for (int i = 0; i < batteries.size(); i++) {
            curr_avl += min(1LL * batteries[i], targetTime);
        }

        return curr_avl >= (ll)n * targetTime;
    }

    long long maxRunTime(int n, vector<int>& batteries) {

        long long totalPower = 0;

        for (int i = 0; i < batteries.size(); i++) {
            totalPower += batteries[i];
        }

        long long s = 0;
        long long e = totalPower / n;

        while (s <= e) {
            long long mid = s + (e - s) / 2;

            if (helper(mid, n, batteries)) {
                s = mid + 1;
            } else {
                e = mid - 1;
            }
        }

        return e;
    }
};
}
}
